@page "/categories"

<PageTitle>分类管理</PageTitle>

<div class="container mt-4">
    <h1>分类管理</h1>
    <p class="text-muted">此页面用于管理收入和支出的分类。</p>
    
    <div class="alert alert-info">
        <h5>功能说明</h5>
        <ul class="mb-0">
            <li>添加、编辑、删除分类</li>
            <li>支持收入分类和支出分类</li>
            <li>为分类设置图标和描述</li>
        </ul>
    </div>
</div>
